# python
# 캐시폴더 제외 : 실행 속도를 높이기 위해 자동으로 생성하는 캐시 디렉토리
# """
# [이유] 실행 환경(OS, 파이썬 버전)에 따라 파일 내용이 매번 자동으로 바뀌기 때문에,
# 원격 저장소에 올리면 무의미한 충돌(Conflict)을 끊임없이 일으켜 협업을 방해합니다.
# """
__pycache__/

# 컴파일 파일 제외 : [cod]는 *.pyc,*.pyo,*.pyd 를 한줄로 표현한 패턴임
# """ [이유] 소스코드가 아닌 파이썬 인터프리터용 실행 파일이므로 버전 관리 대상이 아닙니다. """
*.py[cod]

# Jython 컴파일 파일 제외
# """ [이유] 자바 가상머신(JVM) 기반의 파이썬 환경(Jython)에서 생성되는 임시 컴파일 파일입니다. """
*$py.class

# 최적화 바이트코드 제외
# """ [이유] 최적화 옵션(-O)을 사용하여 코드를 실행할 때 백그라운드에서 자동 생성되는 캐시입니다. """
*.pyo

# Windows 파이썬 확장 모듈 (DLL과 유사함)
# """ [이유] C/C++로 빌드된 바이너리 모듈 파일로, 소스코드가 아니기 때문에 제외합니다. """
*.pyd

# 가상환경
# """
# [이유]
# - .venv / env / ENV : 외부 패키지들이 저장되는 대용량 폴더입니다. (깃에는 패키지 리스트 파일만 올립니다.)
# - .env : 데이터베이스 암호, 오픈 API 키 등 외부 노출 시 해킹 위험이 있는 초민감 보안 파일입니다.
# """
.venv/
.env
env/
ENV/

# 파이참
# """
# [이유] PyCharm(.idea)이나 VS Code(.vscode) 등 에디터가 생성하는 개인 설정 파일입니다.
# 개발자마다 화면 테마, 폰트 등이 달라 공유 시 타인의 코딩 환경을 강제로 덮어쓰게 됩니다.
# """
.idea/
.vscode/
*.iml

# 운영체제 임시 파일
# """
# [이유] Mac(.DS_Store)과 Windows(Thumbs.db)가 뷰어 최적화를 위해 자체 생성하는 임시 파일입니다.
# 프로젝트 코드와 무관하며, 서로 다른 OS 사용자끼리 협업할 때 프로젝트를 지저분하게 만듭니다.
# """
.DS_Store
Thumbs.db

# 임시 실행 결과 파일들 : 로그
# """ [이유] 프로그램이 구동되면서 실시간으로 기록되는 파일들로, 매초 내용이 바뀌어 깃 이력을 더럽힙니다. """
*.log
*.tmp
*.bak

# Jupyter 관련 파일
# """ [이유] 주피터 노트북 편집 중 예기치 못한 종료를 대비해 백그라운드에서 자동 생성되는 체크포인트 파일입니다. """
.ipynb_checkpoints/

# 실습중 자동 생성될 수 있는 데이터 파일
# 팀원간 필요시 개별적으로 주고 받기함 (sns,discord 등)
# """
# [이유] 수만 줄 이상의 말뭉치(Corpus)나 데이터셋은 깃허브의 파일당 용량 제한(100MB)에 걸려
# 업로드가 전면 차단되므로, 안내된 대로 별도 채널을 통해 공유하는 것이 표준 프로토콜입니다.
# """
*.csv
# *.txt
*.xlsx

# 학습된 모델 / 벡터 파일
# 대용량 파일은 깃 허브에 올리지 않음
# """
# [이유] Word2Vec이나 LLM 임베딩 가중치가 담긴 바이너리 파일들은 파일 용량이 최소 수백 MB에서
# 수십 GB에 육박하므로 깃허브 용량 제한을 무조건 초과합니다. 모델은 Hugging Face나 S3에 업로드해야 합니다.
# """
*.model
*.kv
*.vec
*.bin
*.gz
eng_w2v
*.npy
*.npz

# matplotlib 등 실행 결과 이미지
# """
# [이유] 데이터 시각화 결과물인 이미지(이진 파일)는 코드가 아니기 때문에 깃이 변경 내역을 추적하지 못하고
# 바뀔 때마다 파일 전체를 새로 누적 저장하므로, 프로젝트 용량을 폭발적으로 증가시키는 원인이 됩니다.
# """
*.png
*.jpg
*.jpeg
*.svg